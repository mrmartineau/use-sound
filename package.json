{
  "name": "@mrmartineau/use-sound",
  "authors": [
    "Josh Comeau",
    "Zander Martineau"
  ],
  "version": "5.1.0-mrmartineau.0",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "repository": "github:mrmartineau/use-sound",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "typings": "dist/index.d.ts",
  "typesVersions": {
    "*": {
      "*": [
        "dist/index.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --target es2020 --dts --sourcemap --clean --external react --external react-dom --external howler",
    "dev": "tsup src/index.ts --format cjs,esm --target es2020 --dts --sourcemap --external react --external react-dom --external howler --watch",
    "prepare": "tsup src/index.ts --format cjs,esm --target es2020 --dts --sourcemap --clean --external react --external react-dom --external howler",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "howler": "^2.2.4"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@chromatic-com/storybook": "^5.0.1",
    "@storybook/addon-a11y": "^10.2.15",
    "@storybook/addon-docs": "^10.2.15",
    "@storybook/addon-vitest": "^10.2.15",
    "@storybook/react-vite": "^10.2.15",
    "@types/howler": "2.2.12",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "~8.56.1",
    "@typescript-eslint/parser": "~8.56.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "babel-eslint": "10.x",
    "babel-loader": "^10.0.0",
    "eslint": "~10.0.2",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-flowtype": "~8.0.3",
    "eslint-plugin-import": "~2.32.0",
    "eslint-plugin-jsx-a11y": "6.x",
    "eslint-plugin-react": "~7.37.5",
    "eslint-plugin-react-hooks": "~7.0.1",
    "eslint-plugin-storybook": "^10.2.15",
    "focus-visible": "^5.0.2",
    "husky": "^9.1.7",
    "playwright": "^1.58.2",
    "prop-types": "^15.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-spring": "^10.0.3",
    "storybook": "^10.2.15",
    "styled-components": "^6.3.11",
    "ts-loader": "^9.5.4",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "react": ">=16.8"
  },
  "prettier": {
    "printWidth": 80,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5"
  }
}
